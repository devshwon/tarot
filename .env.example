# GPT API (AI 타로 해석용)
#
# OpenAI 키는 클라이언트(.env, 코드, 빌드 산출물)에 절대 두지 않는다.
# 'VITE_' 접두사 환경변수는 빌드 시 클라이언트 번들에 평문으로 박히므로,
# 키는 항상 별도 프록시 서버(Cloudflare Workers 등)의 secret 에만 둔다.
#
# 프록시는 POST /v1/chat/completions 를 받아 OpenAI 로 forward 한다.
# 본 레포의 proxy/ 폴더에 Cloudflare Workers 구현이 들어 있다.
VITE_GPT_PROXY=https://your-gpt-proxy.workers.dev

# 사용할 모델 (선택, 기본값: gpt-4o-mini)
# VITE_GPT_MODEL=gpt-4o-mini

# 리워드 광고 그룹 ID (앱인토스, 추가 해석 보기 연동)
# VITE_AD_UNIT_ID=ait.v2.live.7ebddeedc12d4298
